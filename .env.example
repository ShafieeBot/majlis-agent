# ── Jemputan app URL (agent calls this for business data) ─────────────────────
APP_URL=https://jemputan.app

# ── Local SQLite database ──────────────────────────────────────────────────────
DB_PATH=./data/agent.db

# ── LLM (OpenAI-compatible) ───────────────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_MODEL=claude-sonnet-4-6
LLM_FALLBACK_MODEL=claude-haiku-4-5-20251001  # Used when primary model returns 529 overloaded

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=       # Optional here — webhook validation is done by the Next.js proxy

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=

# ── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: All secrets MUST be at least 16 characters and randomly generated.
# Use: openssl rand -base64 32
# Do NOT use weak values like 'localdevsecret', 'secret', 'password' etc.
APP_SECRET=                    # Must match the main app's APP_SECRET (for PIN derivation)
AGENT_SERVICE_SECRET=          # Shared secret — Next.js sends this header, agent validates it
ADMIN_SECRET=                  # GAP-A2: Separate secret for admin panel access (optional, falls back to AGENT_SERVICE_SECRET)

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=          # Comma-separated origins (defaults to APP_URL)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                 # debug | info | warn | error
NODE_ENV=production            # development | production

# ── Error Tracking ────────────────────────────────────────────────────────────
SENTRY_DSN=                   # GAP-O2: Sentry DSN for error tracking (optional — disabled when empty)

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

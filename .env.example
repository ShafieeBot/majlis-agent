# ── Jemputan app URL (agent calls this for business data) ─────────────────────
APP_URL=https://jemputan.app

# ── Local SQLite database ──────────────────────────────────────────────────────
DB_PATH=./data/agent.db

# ── LLM (OpenAI-compatible) ───────────────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_MODEL=claude-sonnet-4-6
LLM_FALLBACK_MODEL=claude-haiku-4-5-20251001  # Used when primary model returns 529 overloaded

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=       # Optional here — webhook validation is done by the Next.js proxy

# ── Security ──────────────────────────────────────────────────────────────────
APP_SECRET=                    # Must match the main app's APP_SECRET (for PIN derivation)
AGENT_SERVICE_SECRET=          # Shared secret — Next.js sends this header, agent validates it

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
